@article{manshaRecentDevelopmentElectrolytes2024,
  title = {Recent {{Development}} of {{Electrolytes}} for {{Aqueous Organic Redox Flow Batteries}} ({{Aorfbs}}): {{Current Status}}, {{Challenges}}, and {{Prospects}}},
  shorttitle = {Recent {{Development}} of {{Electrolytes}} for {{Aqueous Organic Redox Flow Batteries}} ({{Aorfbs}})},
  author = {Mansha, Muhammad and Ayub, Asif and Khan, Ibad Ali and Ali, Shahid and Alzahrani, Atif Saeed and Khan, Majad and Arshad, Muhammad and Rauf, Abdul and Akram Khan, Safyan},
  year = 2024,
  journal = {The Chemical Record},
  volume = {24},
  number = {1},
  pages = {e202300284},
  issn = {1528-0691},
  doi = {10.1002/tcr.202300284},
  urldate = {2025-10-13},
  abstract = {In recent years, aqueous organic redox flow batteries (AORFBs) have attracted considerable attention due to advancements in grid-level energy storage capacity research. These batteries offer remarkable benefits, including outstanding capacity retention, excellent cell performance, high energy density, and cost-effectiveness. The organic electrolytes in AORFBs exhibit adjustable redox potentials and tunable solubilities in water. Previously, various types of organic electrolytes, such as quinones, organometallic complexes, viologens, redox-active polymers, and organic salts, were extensively investigated for their electrochemical performance and stability. This study presents an overview of recently published novel organic electrolytes for AORFBs in acidic, alkaline, and neutral environments. Furthermore, it delves into the current status, challenges, and prospects of AORFBs, highlighting different strategies to overcome these challenges, with special emphasis placed on their design, composition, functionalities, and cost. A brief techno-economic analysis of various aqueous RFBs is also outlined, considering their potential scalability and integration with renewable energy systems.},
  copyright = {{\copyright} 2023 The Chemical Society of Japan \& Wiley-VCH GmbH},
  langid = {english},
  keywords = {advantages of AORFBs,challenges,grid-scale storage,molecular engineering,Organic electrolytes,technoeconomic analysis},
  file = {/Users/bm522/Zotero/storage/EHW92NBX/Mansha et al. - 2024 - Recent Development of Electrolytes for Aqueous Organic Redox Flow Batteries (Aorfbs) Current Status.pdf;/Users/bm522/Zotero/storage/MAGZAF29/tcr.html}
}

